# Credentials for n8n application after create 
# NOTE: this not auto create when docker run, 
# you need to create it by yourself and add to .env file, 
# then restart docker container to apply changes
USER_NAME=your_email_here
PASSWORD=your_password_here

# PostgreSQL Database Configuration
POSTGRESQL_DATABASE=n8n
POSTGRESQL_USER=postgres
POSTGRESQL_PASSWORD=root1234
POSTGRESQL_PORT=5432

# Database Host Configuration
DB_POSTGRESDB_HOST=postgresql

# Timezone Configuration
GENERIC_TIMEZONE=UTC

# gemini api token
gemini_api_token=your_gemini_api_token_here

# gg oauth configuration from gcp
google_client_id=your_google_client_id_here
google_client_secret=your_google_client_secret_here
