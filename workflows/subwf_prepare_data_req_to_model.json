      "name": "Get info top log data"
    },
    {
      "parameters": {
        "jsCode": "const items = $(\"Get info top log data\").all() || [];\nconst K = 5;\n\n// Sort mới nhất trước\nconst sorted = [...items].sort((a, b) => b.json.timestamp - a.json.timestamp);\n\n// Lấy top K chat_input (loại bỏ rỗng + trim)\nconst topMessages = sorted\n  .map(item => (item.json.chat_input || \"\").trim())\n  .filter(text => text !== \"\")\n  .slice(0, K);\n\n// Xác định current và previous\nconst currentChatInput = topMessages[0] || \"\";\nconst previousChatInput = topMessages[1] || \"\";\n\nreturn [\n  {\n    json: {\n      data: {\n        current_chat_input: currentChatInput,\n        previous_chat_input: previousChatInput,\n        top_messages: topMessages\n      }\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1264,
        -80
      ],
      "id": "f05c88af-712b-4555-b2d5-a7b926630691",
      "name": "output_data_gen"
    },
    {
      "parameters": {
        "jsCode": "const data = $(\"get logs for analyze\").all();\nconst top_message_get = 5;\nlet targetTimestamp;\nlet targetSession;\n\ntry {\n  const node = $('Handle create data with mode').first();\n  targetTimestamp = Number(node?.json?.timestamp);\n  targetSession = node?.json?.session_id;\n} catch (e) {\n  targetTimestamp = NaN;\n  targetSession = null;\n}\n\nif (isNaN(targetTimestamp)) {\n  targetTimestamp = Date.now();\n}\n\nif (!targetSession) {\n  return [];\n}\n\nlet closestImage = null;\nlet minImageDiff = Infinity;\n\nconst topMessages = [];\n\nfor (const item of data) {\n  const json = item.json;\n\n  if (json.session_id !== targetSession) continue;\n\n  const ts = Number(json.timestamp);\n  if (isNaN(ts)) continue;\n\n  const diff = Math.abs(ts - targetTimestamp);\n\n  const isImage =\n    json.has_file === true ||\n    (typeof json.file_res === \"string\" && json.file_res.trim() !== \"\");\n\n  const isMessage =\n    typeof json.chat_input === \"string\" &&\n    json.chat_input.trim() !== \"\";\n\n  // ===== ẢNH GẦN NHẤT =====\n  if (isImage) {\n    if (diff < minImageDiff) {\n      minImageDiff = diff;\n      closestImage = item;\n    }\n  }\n\n  // ===== TOP top_message_get MESSAGE =====\n  if (isMessage) {\n    if (topMessages.length < top_message_get) {\n      topMessages.push({ item, diff });\n    } else {\n      let maxIndex = 0;\n      for (let i = 1; i < 5; i++) {\n        if (topMessages[i].diff > topMessages[maxIndex].diff) {\n          maxIndex = i;\n        }\n      }\n\n      if (diff < topMessages[maxIndex].diff) {\n        topMessages[maxIndex] = { item, diff };\n      }\n    }\n  }\n}\n\ntopMessages.sort((a, b) => a.diff - b.diff);\n\nconst result = [];\n\nif (closestImage) result.push(closestImage);\nresult.push(...topMessages.map(x => x.item));\n\nreturn result;"
      },
