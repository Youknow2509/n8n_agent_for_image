    {
      "parameters": {
        "jsCode": "const allItems = $(\"Get info top log data2\").all();\n\n// Sắp xếp theo timestamp tăng dần\nallItems.sort((a, b) => a.json.timestamp - b.json.timestamp);\n\n/**\n * Hàm chuẩn hóa record\n */\nfunction mapRecord(record) {\n  return {\n    message: record.chat_input || \"\",\n    have_img: Boolean(record.has_file || record.has_file_res || false),\n    data_field: `${record.session_id}_${record.timestamp}`\n  };\n}\n\n/**\n * get current chat input \n * return: {\n *  \"message\": string,\n *  \"have_img\": bool,\n *  \"data_field\": string,\n * }\n */ \n// Record cuối là current\nconst lastIndex = allItems.length - 1;\n\nlet current_chat_input = mapRecord(allItems[lastIndex].json);\n\n/**\n * get list chat previous\n * return: [{\n *  \"message\": string,\n *  \"have_img\": bool,\n *  \"data_field\": string,\n * }, ...]\n */\nlet previous_chat_input = allItems\n  .slice(0, lastIndex)\n  .map(item => mapRecord(item.json));\n\n// Get binary files\nconst fileItems = $(\"get_list_data_files\").all();\n\nlet binary_files = {};\n\nfor (const item of fileItems) {\n  if (item.binary) {\n    binary_files = {\n      ...binary_files,\n      ...item.binary\n    };\n  }\n}\nreturn {\n  binary: binary_files,\n  json: {\n    current_chat_input,\n    previous_chat_input\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
