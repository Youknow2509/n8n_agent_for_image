    {
      "parameters": {
        "jsCode": "const data = $(\"Get info top log data have image in session\").all();\n\nlet latestImage = null;\nlet latestImageTs = -Infinity;\n\nconst message_get = 5;\nconst topMessages = [];\n\nfor (const item of data) {\n  const json = item.json;\n\n  const ts = Number(json.timestamp);\n  if (isNaN(ts)) continue;\n\n  const chatInput = (json.chat_input || \"\").trim();\n\n  // =====================================\n  // ƯU TIÊN has_file_res trước\n  // =====================================\n  let selectedImage = null;\n  let selectedImageType = null;\n\n  if (\n    json.has_file_res === true &&\n    typeof json.file_res === \"string\" &&\n    json.file_res.trim() !== \"\"\n  ) {\n    selectedImage = json.file_res.trim();\n    selectedImageType = \"result_image\";\n  } \n  else if (\n    json.has_file === true &&\n    typeof json.file_name === \"string\" &&\n    json.file_name.trim() !== \"\"\n  ) {\n    selectedImage = json.file_name.trim();\n    selectedImageType = \"input_image\";\n  }\n\n  const isImage = selectedImage !== null;\n  const isMessage = chatInput !== \"\";\n\n  // ===== 1. Lấy image mới nhất =====\n  if (isImage && ts > latestImageTs) {\n    latestImageTs = ts;\n\n    // Mapping file_id theo loại ảnh\n    const mappedFileId =\n      selectedImageType === \"result_image\"\n        ? (json.file_res_id || \"\").trim()\n        : (json.file_id || \"\").trim();\n\n    latestImage = {\n      selected_image: selectedImage,\n      selected_image_type: selectedImageType,\n      chat_input: chatInput,\n      timestamp: ts,\n      file_id: mappedFileId\n    };\n  }\n\n  // ===== 2. Lấy top 5 message gần nhất =====\n  if (isMessage) {\n    if (topMessages.length < message_get) {\n      topMessages.push({ item, ts });\n    } else {\n      let minIndex = 0;\n\n      for (let i = 1; i < topMessages.length; i++) {\n        if (topMessages[i].ts < topMessages[minIndex].ts) {\n          minIndex = i;\n        }\n      }\n\n      if (ts > topMessages[minIndex].ts) {\n        topMessages[minIndex] = { item, ts };\n      }\n    }\n  }\n}\n\n// Sort lại theo timestamp giảm dần\ntopMessages.sort((a, b) => b.ts - a.ts);\n\n// ===== 3. Tách current & previous =====\nconst currentChat = topMessages[0]?.item.json.chat_input?.trim() || \"\";\nconst previousChat = topMessages[1]?.item.json.chat_input?.trim() || \"\";\n\n// ===== 4. Trả kết quả =====\nreturn {\n  image: latestImage,\n\n  current_chat_input: currentChat,\n  previous_chat_input: previousChat,\n\n  top_messages: topMessages.map(x =>\n    (x.item.json.chat_input || \"\").trim()\n  )\n};"
      },
