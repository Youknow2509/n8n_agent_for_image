      "parameters": {
        "jsCode": "const items = $(\"get logs for gen\").all();\nconst K = 3;\n\nconst sorted = items\n  .map(i => i.json)\n  .sort((a, b) => b.timestamp - a.timestamp)\n  .slice(0, K);\n\nreturn sorted.map(item => ({ json: item }));"
